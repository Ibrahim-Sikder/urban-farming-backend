{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "removeComments": true,
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": false,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": false,
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/app/config": ["./src/app/config/index.ts"],
      "@/app/config/*": ["./src/app/config/*"],
      "@/app/shared/*": ["./src/app/shared/*"],
      "@/app/shared/middleware/*": ["./src/app/shared/middleware/*"],
      "@/app/shared/utils/*": ["./src/app/shared/utils/*"],
      "@modules/*": ["./src/app/modules/*"],
      "@utils/*": ["./src/app/utils/*"],
      "@config/*": ["./src/app/config/*"],
      "@middlewares/*": ["./src/app/middlewares/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "coverage", "prisma/**/*"]
}
