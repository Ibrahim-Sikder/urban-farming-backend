generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum HealthStatus {
  HEALTHY
  MODERATE
  CRITICAL
  HARVEST_READY
}

enum GrowthStage {
  SEEDLING
  VEGETATIVE
  FLOWERING
  FRUITING
  HARVESTING
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  phoneNumber  String?
  address      String?
  profileImage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // Relations
  vendorProfile       VendorProfile?
  orders              Order[]
  communityPosts      CommunityPost[]
  plantTrackings      PlantTracking[]
  rentalBookings      RentalBooking[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  communityComments   CommunityComment[]
  cartItems           CartItem[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([role, status])
}

model VendorProfile {
  id                  Int                 @id @default(autoincrement())
  userId              Int                 @unique
  farmName            String
  certificationStatus CertificationStatus @default(PENDING)
  farmLocation        String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce             Produce[]
  rentalSpaces        RentalSpace[]
  orders              Order[]
  sustainabilityCert  SustainabilityCert?

  @@index([certificationStatus])
  @@index([userId])
  @@index([createdAt])
}

model Produce {
  id                  Int                 @id @default(autoincrement())
  vendorId            Int
  name                String
  description         String
  price               Float
  category            String
  certificationStatus CertificationStatus @default(PENDING)
  availableQuantity   Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  vendor              VendorProfile       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders              Order[]
  cartItems           CartItem[]

  @@index([vendorId])
  @@index([category])
  @@index([certificationStatus])
  @@index([price])
  @@index([createdAt])
  @@index([vendorId, certificationStatus])
}

model RentalSpace {
  id           Int             @id @default(autoincrement())
  vendorId     Int
  location     String
  size         Float
  price        Float
  availability Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vendor       VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings     RentalBooking[]

  @@index([vendorId])
  @@index([availability])
  @@index([location])
  @@index([price])
  @@index([availability, price])
}

model RentalBooking {
  id        Int         @id @default(autoincrement())
  spaceId   Int
  userId    Int
  startDate DateTime
  endDate   DateTime
  status    OrderStatus @default(PENDING)
  orderDate DateTime    @default(now())
  space     RentalSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([spaceId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([userId, status])
}

model Order {
  id         Int           @id @default(autoincrement())
  userId     Int
  produceId  Int
  vendorId   Int
  quantity   Int
  totalPrice Float
  status     OrderStatus   @default(PENDING)
  orderDate  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id])
  produce    Produce       @relation(fields: [produceId], references: [id])
  vendor     VendorProfile @relation(fields: [vendorId], references: [id])

  @@index([userId])
  @@index([vendorId])
  @@index([status])
  @@index([orderDate])
  @@index([userId, status])
  @@index([vendorId, orderDate])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  produceId Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  produce Produce @relation(fields: [produceId], references: [id])

  @@unique([userId, produceId])
  @@index([userId])
  @@index([produceId])
}

model CommunityPost {
  id          Int                @id @default(autoincrement())
  userId      Int
  postContent String             @db.Text
  postDate    DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    CommunityComment[]

  @@index([userId])
  @@index([postDate])
  @@index([userId, postDate])
}

model CommunityComment {
  id        Int           @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String        @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@index([postId, createdAt])
}

model PlantTracking {
  id                  Int          @id @default(autoincrement())
  userId              Int
  plantName           String
  plantType           String
  plantedDate         DateTime
  expectedHarvestDate DateTime
  actualHarvestDate   DateTime?
  healthStatus        HealthStatus @default(HEALTHY)
  growthStage         GrowthStage  @default(SEEDLING)
  notes               String?
  lastUpdated         DateTime     @updatedAt
  createdAt           DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([healthStatus])
  @@index([growthStage])
  @@index([expectedHarvestDate])
  @@index([userId, healthStatus])
  @@index([userId, growthStage])
}

model SustainabilityCert {
  id                 Int                 @id @default(autoincrement())
  vendorId           Int                 @unique
  certifyingAgency   String
  certificationDate  DateTime
  expiryDate         DateTime?
  documentUrl        String?
  verificationStatus CertificationStatus @default(PENDING)
  verifiedBy         Int?
  verifiedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  vendor             VendorProfile       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([verificationStatus])
  @@index([expiryDate])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([email])
  @@index([expiresAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  email     String?
  action    String
  entity    String
  entityId  Int?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

model BenchmarkReport {
  id          String   @id
  report_data Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([created_at])
}
