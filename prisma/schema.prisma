generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum HealthStatus {
  HEALTHY
  MODERATE
  CRITICAL
  HARVEST_READY
}

enum GrowthStage {
  SEEDLING
  VEGETATIVE
  FLOWERING
  FRUITING
  HARVESTING
}

// ===================== CORE MODELS =====================

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  phoneNumber  String?
  address      String?
  profileImage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // Relations
  vendorProfile       VendorProfile?
  orders              Order[]
  communityPosts      CommunityPost[]
  plantTrackings      PlantTracking[]
  rentalBookings      RentalBooking[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  communityComments   CommunityComment[]
  cartItems           CartItem[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model VendorProfile {
  id                  Int                 @id @default(autoincrement())
  userId              Int                 @unique
  farmName            String
  certificationStatus CertificationStatus @default(PENDING)
  farmLocation        String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce            Produce[]
  rentalSpaces       RentalSpace[]
  orders             Order[]
  sustainabilityCert SustainabilityCert?

  @@index([certificationStatus])
  @@index([userId])
}

model Produce {
  id                  Int                 @id @default(autoincrement())
  vendorId            Int
  name                String
  description         String
  price               Float
  category            String
  certificationStatus CertificationStatus @default(PENDING)
  availableQuantity   Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  vendor    VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders    Order[]
  cartItems CartItem[]

  @@index([vendorId])
  @@index([category])
  @@index([certificationStatus])
}

model RentalSpace {
  id           Int      @id @default(autoincrement())
  vendorId     Int
  location     String
  size         Float
  price        Float
  availability Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  vendor   VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings RentalBooking[]

  @@index([vendorId])
  @@index([availability])
  @@index([location])
}

model RentalBooking {
  id        Int         @id @default(autoincrement())
  spaceId   Int
  userId    Int
  startDate DateTime
  endDate   DateTime
  status    OrderStatus @default(PENDING)
  orderDate DateTime    @default(now())

  // Relations
  space RentalSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([spaceId])
  @@index([status])
}

model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  produceId  Int
  vendorId   Int
  quantity   Int
  totalPrice Float
  status     OrderStatus @default(PENDING)
  orderDate  DateTime    @default(now())

  // Relations
  user    User          @relation(fields: [userId], references: [id])
  produce Produce       @relation(fields: [produceId], references: [id])
  vendor  VendorProfile @relation(fields: [vendorId], references: [id])

  @@index([userId])
  @@index([vendorId])
  @@index([status])
  @@index([orderDate])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  produceId Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  produce Produce @relation(fields: [produceId], references: [id])

  @@unique([userId, produceId])
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  userId      Int
  postContent String   @db.Text
  postDate    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments CommunityComment[] // এই লাইনটি যোগ করুন

  @@index([userId])
  @@index([postDate])
}

// ============ যোগ করুন: CommunityComment মডেল ============
model CommunityComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

// =====================================================
model PlantTracking {
  id                  Int          @id @default(autoincrement())
  userId              Int
  plantName           String
  plantType           String
  plantedDate         DateTime
  expectedHarvestDate DateTime
  actualHarvestDate   DateTime?
  healthStatus        HealthStatus @default(HEALTHY)
  growthStage         GrowthStage  @default(SEEDLING)
  notes               String?
  lastUpdated         DateTime     @updatedAt
  createdAt           DateTime     @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([healthStatus])
  @@index([expectedHarvestDate])
}

model SustainabilityCert {
  id                 Int                 @id @default(autoincrement())
  vendorId           Int                 @unique
  certifyingAgency   String
  certificationDate  DateTime
  expiryDate         DateTime?
  documentUrl        String?
  verificationStatus CertificationStatus @default(PENDING)
  verifiedBy         Int?
  verifiedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations - Fixed: Only one relation to VendorProfile
  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([verificationStatus])
  @@index([expiryDate])
}

// ===================== AUTH MODELS =====================

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int?

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([email])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  email     String?
  action    String
  entity    String
  entityId  Int?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
