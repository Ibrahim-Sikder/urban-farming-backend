{
  "name": "urban-farming-backend",
  "version": "1.0.0",
  "description": "Urban Farming Platform Backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "start": "node -r module-alias/register dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "_moduleAliases": {
    "@": "dist",
    "@modules": "dist/app/modules",
    "@utils": "dist/app/utils",
    "@config": "dist/app/config",
    "@middlewares": "dist/app/middlewares"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/ioredis": "^4.28.10",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "prisma": "^5.22.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
