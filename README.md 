📊 Database Schema
Core Models
prisma
model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  phoneNumber  String?
  address      String?
  createdAt    DateTime   @default(now())
}

model VendorProfile {
  id                  Int                 @id @default(autoincrement())
  userId              Int                 @unique
  farmName            String
  certificationStatus CertificationStatus @default(PENDING)
  farmLocation        String
}

model Produce {
  id                  Int                 @id @default(autoincrement())
  vendorId            Int
  name                String
  price               Float
  category            String
  availableQuantity   Int
  certificationStatus CertificationStatus @default(PENDING)
}

model RentalSpace {
  id           Int      @id @default(autoincrement())
  vendorId     Int
  location     String
  size         Float
  price        Float
  availability Boolean  @default(true)
}

model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  produceId  Int
  vendorId   Int
  quantity   Int
  totalPrice Float
  status     OrderStatus @default(PENDING)
  orderDate  DateTime    @default(now())
}

model PlantTracking {
  id                  Int          @id @default(autoincrement())
  userId              Int
  plantName           String
  healthStatus        HealthStatus @default(HEALTHY)
  growthStage         GrowthStage  @default(SEEDLING)
  expectedHarvestDate DateTime
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  userId      Int
  postContent String   @db.Text
  postDate    DateTime @default(now())
}
