🚀 Deployment
Docker Deployment
yaml
# docker-compose.yml
version: '3.8'

services:
  postgres:
    image: postgres:15
    container_name: urban_farming_postgres
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres123
      POSTGRES_DB: urban_farming
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - urban_farming_network

  redis:
    image: redis:7-alpine
    container_name: urban_farming_redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - urban_farming_network

  app:
    build: .
    container_name: urban_farming_app
    ports:
      - "5000:5000"
    environment:
      NODE_ENV: production
      DATABASE_URL: postgresql://postgres:postgres123@postgres:5432/urban_farming
      REDIS_HOST: redis
      REDIS_PORT: 6379
    depends_on:
      - postgres
      - redis
    networks:
      - urban_farming_network

volumes:
  postgres_data:
  redis_data:

networks:
  urban_farming_network:
    driver: bridge
