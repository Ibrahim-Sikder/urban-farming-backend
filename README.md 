🔌 Real-time Events (Socket.IO)
Connection
javascript
import { io } from 'socket.io-client';

const socket = io('http://localhost:5000', {
    auth: { token: 'your_jwt_token' },
    transports: ['websocket']
});

socket.on('connect', () => {
    console.log('Connected to WebSocket server');
});
Complete Event List
Event	Direction	Trigger	Data Received
order:new	Server → Vendor	Customer places order	{ orderId, customerName, productName, quantity, totalPrice }
order:status:updated	Server → Customer	Vendor updates order status	{ orderId, status, timestamp }
booking:new	Server → Vendor	Customer creates booking	{ bookingId, customerName, startDate, endDate }
booking:status:updated	Server → Customer	Vendor updates booking	{ bookingId, status, timestamp }
plant:health:updated	Server → Customer	Plant health changes	{ plantId, plantName, healthStatus, growthStage }
plant:ready:harvest	Server → Customer	Plant ready for harvest	{ plantId, plantName, message }
comment:new	Server → Author	New comment on post	{ postId, commenterName, content }
certification:status	Server → Vendor	Certification approved/rejected	{ vendorId, status, message }
notification:new	Server → User	General notification	{ title, message, type, timestamp }
Client Example
javascript
// Listen for new orders (Vendor)
socket.on('order:new', (data) => {
    console.log(`New order from ${data.customerName}`);
    showToastNotification(`Order #${data.orderId}: ${data.productName} x${data.quantity}`);
});

// Listen for order status updates (Customer)
socket.on('order:status:updated', (data) => {
    console.log(`Order #${data.orderId} status: ${data.status}`);
    updateOrderStatus(data.orderId, data.status);
});

// Listen for plant health alerts
socket.on('plant:health:updated', (data) => {
    if (data.healthStatus === 'CRITICAL') {
        alert(`⚠️ ${data.plantName} needs immediate attention!`);
    }
});
